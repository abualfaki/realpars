# =============================================================================
# Dagster Pipeline Environment Variables
# Copy this file to ../../.env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Airbyte Configuration
# -----------------------------------------------------------------------------
# Airbyte Cloud API Token (get from: https://cloud.airbyte.com/settings/applications)
AIRBYTE_API_TOKEN=your_airbyte_api_token_here

# Airbyte Workspace ID
AIRBYTE_WORKSPACE_ID=your_workspace_id

# Airbyte Connection IDs (one per data source)
# Get these from Airbyte Cloud → Connections → Click connection → Copy ID from URL
AIRBYTE_CONNECTION_ID_COMMUNITY_MEMBERS_TABLES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AIRBYTE_CONNECTION_ID_COMMENTS_TABLE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AIRBYTE_CONNECTION_ID_EVENTS_LIST_&_ATTENDEES_TABLES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AIRBYTE_CONNECTION_ID_MEMEBER_TAGS_TABLE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AIRBYTE_CONNECTION_ID_POSTS_TABLE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Make.com Webhook Configuration
# -----------------------------------------------------------------------------
# Make.com Webhook URL for triggering email automation
# Get this from: Make.com → Your Scenario → Replace Schedule with Webhook → Copy URL
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id-here

# -----------------------------------------------------------------------------
# Google Cloud Configuration (already in main .env)
# -----------------------------------------------------------------------------
# These should already be set in your root .env file:
# PROJECT_ID=circle-analytics-468017
# GOOGLE_APPLICATION_CREDENTIALS=secrets/GOOGLE-SA-KEY.json
# BQ_RAW_DATASET=circle_community_raw_datasets
# BQ_STG_CLEAN_DATASET=cc_staging_dataset
# etc.
